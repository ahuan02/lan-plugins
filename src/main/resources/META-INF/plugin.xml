<idea-plugin>
    <id>com.ide.plugin</id>
    <name>LAN‑Partner</name>
    <version>1.0</version>
    <vendor email="1422820234@qq.com" url="https://github.com/ahuan02">Sun Mou</vendor>

    <description><![CDATA[
      Local area network chat and file‑transfer plugin.
      After connecting to the server within the same LAN, you can send real‑time messages and share files.
    ]]></description>
    <change-notes><![CDATA[
      v1.0 - Support text chat, file transfer and online user list.
    ]]></change-notes>

    <idea-version since-build="232"/>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="LanPartnerWindow"
                    anchor="right"
                    secondary="false"
                    icon="AllIcons.General.User"
                    factoryClass="com.ide.plugin.factory.MyToolWindowFactory"/>
        <notificationGroup id="LanPartner.Notifications"
                           displayType="BALLOON"
                           isLogByDefault="false"/>
    </extensions>

    <actions>
        <action id="sidebarMenuButtonId"
                class="com.ide.plugin.buttons.SidebarMenuButton"
                text="LAN‑Partner"
                description="Open LAN‑chat panel">
            <add-to-group group-id="HelpMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>